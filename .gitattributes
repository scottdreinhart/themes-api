# -- Line ending normalization ------------------------------------------
* text=auto

# Force LF for shell scripts (must work in WSL/Linux)
*.sh text eol=lf

# Force CRLF for Windows batch files
*.bat text eol=crlf

# -- Binary files -------------------------------------------------------
*.png binary

# -- GitHub Linguist overrides ------------------------------------------
# Hide lock file from diffs and language stats
pnpm-lock.yaml linguist-generated
