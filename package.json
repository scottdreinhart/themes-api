{
  "name": "themes-api",
  "version": "1.0.0",
  "description": "Themes API",
  "type": "module",
  "private": true,
  "license": "PROPRIETARY",
  "author": "Scott Reinhart",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": "24.14.0",
    "npm": "11.9.0",
    "pnpm": "10.31.0"
  },
  "scripts": {
    "start": "node --import tsx/esm src/server.ts",
    "dev": "node --import tsx/esm --watch src/server.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "preview": "node dist/server.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck",
    "fix": "pnpm lint:fix && pnpm format",
    "validate": "pnpm check && pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist",
    "clean:node": "rimraf node_modules",
    "clean:all": "rimraf dist node_modules",
    "reinstall": "pnpm clean:all && pnpm install",
    "prebuild": "pnpm clean",
    "db:migrate": "echo 'TODO: add migration runner'",
    "db:seed": "echo 'TODO: add seed script'"
  },
  "dependencies": {
    "@fastify/autoload": "6.3.1",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/sensible": "6.0.4",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "fastify": "5.8.2",
    "pino": "9.14.0",
    "pino-pretty": "13.1.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.3.5",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-boundaries": "5.4.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "tsc-alias": "1.8.16",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "3.2.4"
  }
}
